rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for all writes, allow public read for app operation
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in [
          'distribucionesquepollodelsur@gmail.com',
          'alex.b19h@gmail.com',
          'alex@quepollo.com',
          'admin@quepollo.com',
          'quepollo@admin.com',
          'alex.quepollo@gmail.com'
        ]
      );
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Permitted for operational flexibility
    }

    // Purchases
    match /purchases/{purchaseId} {
      allow read: if true;
      allow write: if true;
    }

    // Sales
    match /sales/{saleId} {
      allow read: if true;
      allow write: if true;
    }

    // CashFlow
    match /cashFlow/{movementId} {
      allow read: if true;
      allow write: if true;
    }

    // Employees
    match /employees/{employeeId} {
      allow read: if true;
      allow write: if true;
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if true;
      allow write: if true;
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if true;
      allow write: if true;
    }

    // Config
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Shifts
    match /shifts/{shiftId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Advances
    match /advances/{advanceId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
