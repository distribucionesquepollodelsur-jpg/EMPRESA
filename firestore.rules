rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      // Temporarily allowing writes if the request is not authenticated 
      // but the collection is known, to support the current custom login system.
      // IN PRODUCTION: You should use real Firebase Auth and change this to return request.auth != null;
      return true; 
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Purchases
    match /purchases/{purchaseId} {
      allow read: if true;
      allow write: if true;
    }

    // Sales
    match /sales/{saleId} {
      allow read: if true;
      allow write: if true;
    }

    // CashFlow
    match /cashFlow/{movementId} {
      allow read: if true;
      allow write: if true;
    }

    // Employees
    match /employees/{employeeId} {
      allow read: if true;
      allow write: if true;
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Advances
    match /advances/{advanceId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Reprimands
    match /reprimands/{reprimandId} {
      allow read: if true;
      allow write: if true;
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Customers
    match /customers/{customerId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Shifts
    match /shifts/{shiftId} {
      allow read: if true;
      allow write: if true;
    }

    // Processings
    match /processings/{processingId} {
      allow read: if true;
      allow write: if true;
    }

    // Dotations
    match /dotations/{dotationId} {
      allow read: if true;
      allow write: if true;
    }

    // Config
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
