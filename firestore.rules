rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'distribucionesquepollodelsur@gmail.com' ||
        request.auth.token.email == 'alex.b19h@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'unit', 'price', 'cost', 'stock']) &&
             data.name is string && data.name.size() <= 100 &&
             data.unit in ['kg', 'und'] &&
             data.price is number && data.price >= 0 &&
             data.cost is number && data.cost >= 0 &&
             data.stock is number;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['saleNumber', 'date', 'items', 'total', 'paidAmount', 'paymentMethod']) &&
             data.saleNumber is number &&
             data.date is string &&
             data.items is list && data.items.size() <= 100 &&
             data.total is number && data.total >= 0 &&
             data.paidAmount is number && data.paidAmount <= data.total &&
             data.paymentMethod in ['cash', 'credit', 'balance'];
    }

    function isValidPurchase(data) {
      return data.keys().hasAll(['purchaseNumber', 'date', 'supplierName', 'items', 'total', 'paidAmount', 'paymentMethod']) &&
             data.purchaseNumber is number &&
             data.date is string &&
             data.supplierName is string &&
             data.items is list && data.items.size() <= 100 &&
             data.total is number && data.total >= 0 &&
             data.paidAmount is number && data.paidAmount <= data.total &&
             data.paymentMethod in ['cash', 'transfer', 'credit', 'balance'];
    }

    function isValidCashMovement(data) {
      return data.keys().hasAll(['date', 'type', 'amount', 'reason']) &&
             data.date is string &&
             data.type in ['entry', 'exit'] &&
             data.amount is number && data.amount >= 0 &&
             data.reason is string && data.reason.size() <= 500;
    }

    function isValidInventoryLog(data) {
      return data.keys().hasAll(['productId', 'productName', 'date', 'oldStock', 'newStock', 'reason']) &&
             data.productId is string &&
             data.productName is string &&
             data.date is string &&
             data.oldStock is number &&
             data.newStock is number &&
             data.reason is string && data.reason.size() <= 1000 &&
             (data.userName is string);
    }

    // --- Rules ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isSignedIn() && (
        isAdmin() || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock'])) ||
        (existing().stock == incoming().stock && isValidProduct(incoming()))
      );
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidSale(incoming()) && isValidId(saleId);
      allow update: if isSignedIn() && isValidSale(incoming()) && (
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasOnly(['paidAmount', 'payments', 'paymentStatus'])
      );
      allow delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidPurchase(incoming()) && isValidId(purchaseId);
      allow update: if isSignedIn() && isValidPurchase(incoming()) && (
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasOnly(['paidAmount', 'payments', 'paymentStatus'])
      );
      allow delete: if isAdmin();
    }

    match /cashFlow/{movementId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidCashMovement(incoming()) && isValidId(movementId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /inventoryLogs/{logId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidInventoryLog(incoming()) && isValidId(logId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /attendance/{attendanceId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /advances/{advanceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reprimands/{reprimandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /customers/{customerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shifts/{shiftId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /processings/{processingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /dotations/{dotationId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow update: if isSignedIn() && (
        isAdmin() || 
        incoming().diff(existing()).affectedKeys().hasOnly(['lastInventoryCheckDate'])
      );
      allow write: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
