{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "System products and materials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "unit": { "type": "string" }
      },
      "required": ["id", "name", "category", "price", "stock", "unit"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Supply purchases",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paidAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "payments": { "type": "array" }
      },
      "required": ["id", "date", "total", "paidAmount"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Customer sales",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paidAmount": { "type": "number" },
        "status": { "type": "string" },
        "payments": { "type": "array" }
      },
      "required": ["id", "date", "total", "paidAmount"]
    },
    "CashMovement": {
      "title": "CashMovement",
      "description": "Daily cash flow records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["entry", "exit"] },
        "amount": { "type": "number" },
        "reason": { "type": "string" }
      },
      "required": ["id", "date", "type", "amount", "reason"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Staff members",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["vendedor", "despresador", "auxiliar", "admin"] },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "salary": { "type": "number" },
        "active": { "type": "boolean" },
        "photo": { "type": "string" }
      },
      "required": ["id", "name", "role", "email", "password", "active"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Employee attendance logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["presente", "falta", "tarde", "permiso"] }
      },
      "required": ["id", "employeeId", "date", "status"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supply partners",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Inventory products" },
    "purchases": { "schema": "Purchase", "description": "Purchase history" },
    "sales": { "schema": "Sale", "description": "Sales history" },
    "cashFlow": { "schema": "CashMovement", "description": "Daily cash flow" },
    "employees": { "schema": "Employee", "description": "Staff roster" },
    "attendance": { "schema": "Attendance", "description": "Daily attendance" },
    "suppliers": { "schema": "Supplier", "description": "Supplier directory" },
    "config": { "schema": "object", "description": "App configuration singleton" }
  }
}
