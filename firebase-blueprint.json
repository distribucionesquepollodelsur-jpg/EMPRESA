{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "System products and materials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string", "enum": ["kg", "und"] },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "initialStock": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "unit", "price", "cost", "stock"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Supply purchases",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "purchaseNumber": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "supplierPhone": { "type": "string" },
        "buyerName": { "type": "string" },
        "buyerPhone": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paidAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "transfer", "credit"] },
        "payments": { "type": "array" }
      },
      "required": ["purchaseNumber", "date", "supplierName", "items", "total", "paidAmount", "paymentMethod"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Customer sales",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "saleNumber": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerPhone": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paidAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "credit"] },
        "payments": { "type": "array" }
      },
      "required": ["saleNumber", "date", "items", "total", "paidAmount", "paymentMethod"]
    },
    "CashMovement": {
      "title": "CashMovement",
      "description": "Daily cash flow records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["entry", "exit"] },
        "amount": { "type": "number" },
        "reason": { "type": "string" }
      },
      "required": ["date", "type", "amount", "reason"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Staff members",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "salary": { "type": "number" },
        "active": { "type": "boolean" },
        "photo": { "type": "string" },
        "restDay": { "type": "number" },
        "position": { "type": "string" },
        "riskLevel": { "type": "number" },
        "personalData": { "type": "object" },
        "references": { "type": "array" }
      },
      "required": ["name", "role", "salary", "active"]
    },
    "JobOffer": {
      "title": "JobOffer",
      "description": "Job vacancy announcements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "requirements": { "type": "array" },
        "salaryRange": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "requirements", "status", "date"]
    },
    "CandidateEvaluation": {
      "title": "CandidateEvaluation",
      "description": "AI-powered evaluations of job candidates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobOfferId": { "type": "string" },
        "candidateName": { "type": "string" },
        "resumeText": { "type": "string" },
        "matchScore": { "type": "number" },
        "eligible": { "type": "boolean" },
        "aiSummary": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["jobOfferId", "candidateName", "matchScore", "eligible", "aiSummary", "date"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Employee attendance logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] }
      },
      "required": ["employeeId", "date", "status"]
    },
    "Advance": {
      "title": "Advance",
      "description": "Salary advances for employees",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" }
      },
      "required": ["employeeId", "date", "amount"]
    },
    "Reprimand": {
      "title": "Reprimand",
      "description": "Employee warnings or deductions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" },
        "type": { "type": "string", "enum": ["time", "salary_day"] },
        "hours": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "resolved"] }
      },
      "required": ["employeeId", "date", "reason", "type", "status"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supply partners",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "nit": { "type": "string" },
        "category": { "type": "string" },
        "initialDebt": { "type": "number" },
        "initialDebtDate": { "type": "string" },
        "initialDebtPayments": { "type": "array" }
      },
      "required": ["name", "phone"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Business clients",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "nit": { "type": "string" },
        "initialDebt": { "type": "number" },
        "initialDebtDate": { "type": "string" },
        "initialDebtPayments": { "type": "array" },
        "balance": { "type": "number", "description": "What the company owes to the customer (Credit)" }
      },
      "required": ["name", "phone"]
    },
    "Processing": {
      "title": "Processing",
      "description": "Deboning/Cutting processes (Despresaje)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "purchaseId": { "type": "string" },
        "inputProductId": { "type": "string" },
        "inputQuantity": { "type": "number" },
        "outputItems": { "type": "array" },
        "totalOutputWeight": { "type": "number" }
      },
      "required": ["date", "purchaseId", "inputProductId", "inputQuantity", "outputItems"]
    },
    "Shift": {
      "title": "Shift",
      "description": "Employee work shifts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string" },
        "clockIn": { "type": "string" },
        "clockOut": { "type": "string" },
        "breakfastStart": { "type": "string" },
        "breakfastEnd": { "type": "string" },
        "lunchStart": { "type": "string" },
        "lunchEnd": { "type": "string" },
        "justification": { "type": "string" }
      },
      "required": ["employeeId", "date"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "logo": { "type": ["string", "null"] },
        "companyName": { "type": "string" },
        "nit": { "type": "string" },
        "phone1": { "type": "string" },
        "phone2": { "type": "string" },
        "address": { "type": "string" },
        "warehouseAddress": { "type": "string" },
        "email": { "type": "string" },
        "manager": { "type": "string" },
        "saleCounter": { "type": "number" },
        "purchaseCounter": { "type": "number" },
        "lastSequenceDate": { "type": "string" },
        "lastInventoryCheckDate": { "type": "string" }
      },
      "required": ["companyName", "nit"]
    },
    "Dotation": {
      "title": "Dotation",
      "description": "Employee equipment allotments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "item": { "type": "string" },
        "quantity": { "type": "number" },
        "details": { "type": "string" }
      },
      "required": ["employeeId", "date", "item", "quantity"]
    },
    "Loan": {
      "title": "Loan",
      "description": "Loans to third parties",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "borrowerName": { "type": "string" },
        "amount": { "type": "number" },
        "cashAmount": { "type": "number" },
        "isEntry": { "type": "boolean" },
        "term": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date" },
        "paidAmount": { "type": "number" },
        "payments": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "paid"] }
      },
      "required": ["borrowerName", "amount", "date", "status"]
    },
    "BusinessLoan": {
      "title": "BusinessLoan",
      "description": "Loans received by the business (Base Loans)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lenderName": { "type": "string" },
        "amount": { "type": "number" },
        "cashAmount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "paidAmount": { "type": "number" },
        "payments": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "paid"] }
      },
      "required": ["lenderName", "amount", "date", "status"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "receipt": { "type": "string" }
      },
      "required": ["date", "category", "amount", "description"]
    },
    "InventoryAdjustment": {
      "title": "InventoryAdjustment",
      "description": "Manual inventory stock adjustments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "oldStock": { "type": "number" },
        "newStock": { "type": "number" },
        "reason": { "type": "string" },
        "userName": { "type": "string" }
      },
      "required": ["productId", "productName", "date", "oldStock", "newStock", "reason"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Company fixed assets (vehicles, machinery, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Vehículo", "Electrodoméstico", "Maquinaria", "Mueble", "Otro"] },
        "value": { "type": "number" },
        "purchaseDate": { "type": "string", "format": "date" },
        "description": { "type": "string" }
      },
      "required": ["name", "category", "value", "purchaseDate"]
    },
    "LaborContract": {
      "title": "LaborContract",
      "description": "Digital labor contracts and employment agreements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "type": { "type": "string", "enum": ["termino_fijo", "termino_indefinido", "obra_labor", "aprendizaje"] },
        "status": { "type": "string", "enum": ["draft", "socializing", "signed", "archived"] },
        "contractText": { "type": "string" },
        "regulationsText": { "type": "string" },
        "dotationText": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "signedAt": { "type": ["string", "null"], "format": "date-time" },
        "signatures": {
          "type": "object",
          "properties": {
            "worker": { "type": ["string", "null"] },
            "employer": { "type": ["string", "null"] },
            "boss": { "type": ["string", "null"] },
            "hr": { "type": ["string", "null"] },
            "legalRep": { "type": ["string", "null"] }
          }
        },
        "attachments": {
          "type": "object",
          "properties": {
            "workerId": { "type": ["string", "null"] },
            "legalRepId": { "type": ["string", "null"] },
            "originalPdf": { "type": ["string", "null"] }
          }
        }
      },
      "required": ["employeeId", "employeeName", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Inventory products" },
    "purchases": { "schema": "Purchase", "description": "Purchase history" },
    "sales": { "schema": "Sale", "description": "Sales history" },
    "cashFlow": { "schema": "CashMovement", "description": "Daily cash flow" },
    "employees": { "schema": "Employee", "description": "Staff roster" },
    "attendance": { "schema": "Attendance", "description": "Daily attendance" },
    "advances": { "schema": "Advance", "description": "Salary advances" },
    "reprimands": { "schema": "Reprimand", "description": "Employee reprimands" },
    "suppliers": { "schema": "Supplier", "description": "Supplier directory" },
    "customers": { "schema": "Customer", "description": "Customer directory" },
    "processings": { "schema": "Processing", "description": "Despresaje records" },
    "shifts": { "schema": "Shift", "description": "Work shifts" },
    "dotations": { "schema": "Dotation", "description": "Equipment allotments" },
    "assets": { "schema": "Asset", "description": "Company fixed assets" },
    "inventoryLogs": { "schema": "InventoryAdjustment", "description": "Manual inventory adjustments" },
    "contracts": { "schema": "LaborContract", "description": "Employee labor contracts" },
    "loans": { "schema": "Loan", "description": "Loans to third parties" },
    "businessLoans": { "schema": "BusinessLoan", "description": "Base business loans" },
    "expenses": { "schema": "Expense", "description": "Business expenses" },
    "jobOffers": { "schema": "JobOffer", "description": "Recruitment job offers" },
    "evaluations": { "schema": "CandidateEvaluation", "description": "AI candidate evaluations" },
    "config": { "schema": "AppConfig", "description": "App configuration" }
  }
}
